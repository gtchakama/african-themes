{
  "name": "Africa - South Africa Table Mountain (Light)",
  "type": "light",
  "colors": {
    "focusBorder": "#007749",
    "foreground": "#212121",
    "selection.background": "#00148922",
    "activityBar.background": "#FAFAFA",
    "activityBar.foreground": "#001489",
    "activityBar.inactiveForeground": "#757575",
    "activityBar.activeBorder": "#E03C31",
    "activityBarBadge.background": "#007749",
    "activityBarBadge.foreground": "#FFFFFF",
    "sideBar.background": "#F5F5F5",
    "sideBar.foreground": "#424242",
    "sideBar.border": "#EEEEEE",
    "sideBarTitle.foreground": "#001489",
    "editor.background": "#FFFFFF",
    "editor.foreground": "#212121",
    "editorLineNumber.foreground": "#BDBDBD",
    "editorLineNumber.activeForeground": "#001489",
    "editorCursor.foreground": "#001489",
    "editor.selectionBackground": "#0014891A",
    "editor.lineHighlightBackground": "#F0F0F0",
    "editorGroupHeader.tabsBackground": "#FAFAFA",
    "tab.activeBackground": "#FFFFFF",
    "tab.activeForeground": "#001489",
    "tab.inactiveBackground": "#FAFAFA",
    "tab.inactiveForeground": "#757575",
    "statusBar.background": "#007749",
    "statusBar.foreground": "#FFFFFF",
    "titleBar.activeBackground": "#FAFAFA",
    "titleBar.activeForeground": "#212121"
  },
  "tokenColors": [
    { "scope": "comment", "settings": { "foreground": "#9E9E9E", "fontStyle": "italic" } },
    { "scope": "keyword, storage.type", "settings": { "foreground": "#E03C31", "fontStyle": "bold" } },
    { "scope": "string", "settings": { "foreground": "#007749" } },
    { "scope": "entity.name.function", "settings": { "foreground": "#0D47A1" } },
    { "scope": "variable", "settings": { "foreground": "#212121" } },
    { "scope": "constant.numeric", "settings": { "foreground": "#C62828" } },
    { "scope": "support.type, entity.name.type", "settings": { "foreground": "#001489" } }
  ]
}
